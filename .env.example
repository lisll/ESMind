# =============================================================================
# ESMind — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# Required: LLM API key (DashScope / OpenAI compatible)
DASHSCOPE_API_KEY=sk-your-api-key-here

# LLM model name (default: qwen-max)
AGENTSCOPE_MODEL=qwen-max

# Elasticsearch connection
ES_HOST=localhost
ES_PORT=9200
ES_SCHEME=http
ES_USERNAME=
ES_PASSWORD=

# Workspace directory (default: .agentscope/workspace)
AGENTSCOPE_WORKSPACE=.agentscope/workspace
