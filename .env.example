# =============================================================================
# ESMind — Environment Variables (optional)
# =============================================================================
# All configuration now lives in src/main/resources/application.properties.
# Environment variables below OVERRIDE file values at runtime.
# Only set these if you need to override config WITHOUT editing the file.
#
# Usage: export DASHSCOPE_API_KEY=sk-xxx
#        mvn compile exec:java -Dexec.mainClass="io.esmind.agent.EsMindAgent"
# =============================================================================

# API key override (takes priority over application.properties)
# DASHSCOPE_API_KEY=sk-xxx

# Model override
# AGENTSCOPE_MODEL=qwen-max

# ES connection override
# ES_HOST=192.168.8.59
# ES_PORT=9230
# ES_SCHEME=http

# Workspace directory override
# AGENTSCOPE_WORKSPACE=.agentscope/workspace
